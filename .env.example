# ────────────────────────────────────────────────────────────────────────────────
# Core paths
# ────────────────────────────────────────────────────────────────────────────────
# Root folder containing your *_diarized_content.json (and sibling .mp3/.wav/.m4a)
YOUTUBE_VIDEO_DIRECTORY=/abs/path/to/your/youtube_assets

# ────────────────────────────────────────────────────────────────────────────────
# OpenAI router enrichment
# ────────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=replace_me
ROUTER_GEN_MODEL=gpt-4o-mini          # or your preferred model
ROUTER_GEN_RETRIES=2
ROUTER_GEN_CONCURRENCY=6
ROUTER_LOG_DESC_CHARS=240

# ────────────────────────────────────────────────────────────────────────────────
# Speaker recognition (Tier-2; fully local with Resemblyzer)
# ────────────────────────────────────────────────────────────────────────────────
# Enable Tier-2
VOICE_EMBED_BACKEND=resemblyzer       # 'resemblyzer' to enable; 'none' to disable

# Where your named voice embeddings live (library.json inside this dir)
VOICE_LIBRARY_DIR=./pipeline_storage_v2/voices

# Where per-video computed (S1/S2/…) embeddings are cached
SPEAKER_EMBED_CACHE_DIR=./pipeline_storage_v2/speaker_embeds

# Match threshold against the library (cosine similarity 0..1)
VOICE_MATCH_THRESHOLD=0.82

# Export a human-auditable speaker map for each processed video
SPEAKER_MAP_DIR=./pipeline_storage_v2/speaker_maps

# ── Optional auto-enrollment of the channel host ───────────────────────────────
# If no library match is found for the primary speaker, auto-enroll them:
VOICE_AUTO_ENROLL=true               # true/false
VOICE_ENROLL_MIN_TALK_S=60           # require at least N seconds of speech to enroll
VOICE_AUTO_ENROLL_NAME=              # if set, force this name; otherwise we derive from channel handle

# ────────────────────────────────────────────────────────────────────────────────
# Logging & misc
# ────────────────────────────────────────────────────────────────────────────────
PYTHONUNBUFFERED=1
LOGLEVEL=INFO
